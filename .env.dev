# TMS development environment variables
NODE_ENV=development
LOG_LEVEL=debug

# JWT
JWT_SECRET=change_me_to_a_long_random_secret_at_least_64_chars
JWT_EXPIRES_IN=1d

# MariaDB
MARIADB_ROOT_PASSWORD=rootpassword
MARIADB_USER=soar
MARIADB_PASSWORD=soarpassword
DB_HOST=localhost
DB_PORT=53306
DB_USER=soar
DB_PASSWORD=soarpassword

# Redis
REDIS_PASSWORD=replace_with_strong_redis_password
REDIS_HOST=localhost
REDIS_PORT=56379

# ClickHouse
CLICKHOUSE_USER=soar
CLICKHOUSE_PASSWORD=clickhousepassword

# Frontend
VITE_API_BASE_URL=http://localhost:4000

# Go Engine Monitoring
GO_ENGINE_HEALTH_URL=http://go-engine-dev:8081/health
GO_ENGINE_METRICS_URL=http://go-engine-dev:8081/metrics

# System Status Monitoring
CLICKHOUSE_HEALTH_URL=http://clickhouse:8123/ping

# Smoke Test Tenant
MASTER_ADMIN_EMAIL=nimo@wins21.co.kr
MASTER_ADMIN_PASSWORD=ChangeMe1234!
SMOKE_TENANT_SLUG=system
SMOKE_TENANT_EMAIL=operator@demo.local
SMOKE_TENANT_PASSWORD=ChangeMe1234!

# Host Ports
PORT_MARIADB=53306
PORT_REDIS=56379
