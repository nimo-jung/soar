# .env.example — 이 파일을 복사하여 .env 로 사용하세요.
# cp .env.example .env
# .env 는 절대 git에 커밋하지 않습니다.

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# ── JWT ───────────────────────────────────────────────────────────────────────
# 운영 환경에서는 반드시 충분히 긴 랜덤 문자열로 교체하세요.
JWT_SECRET=change_me_to_a_long_random_secret_at_least_64_chars
JWT_EXPIRES_IN=1d

# ── MariaDB ───────────────────────────────────────────────────────────────────
MARIADB_ROOT_PASSWORD=rootpassword
MARIADB_USER=soar
MARIADB_PASSWORD=soarpassword
DB_HOST=localhost
DB_PORT=3306
DB_USER=soar
DB_PASSWORD=soarpassword

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redispassword

# ── ClickHouse ────────────────────────────────────────────────────────────────
CLICKHOUSE_HOST=localhost
CLICKHOUSE_USER=soar
CLICKHOUSE_PASSWORD=clickhousepassword

# ── Master Admin Seed ─────────────────────────────────────────────────────────
MASTER_ADMIN_EMAIL=admin@soar.io
MASTER_ADMIN_PASSWORD=ChangeMe1234!

# ── Smoke Test Tenant (optional) ──────────────────────────────────────────────
SMOKE_TENANT_SLUG=demo
SMOKE_TENANT_EMAIL=operator@demo.local
SMOKE_TENANT_PASSWORD=Demo1234!

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:3000

# ── Go Engine Monitoring ─────────────────────────────────────────────────────
GO_ENGINE_HEALTH_URL=http://localhost:8081/health
GO_ENGINE_METRICS_URL=http://localhost:8081/metrics

# ── Host Ports ────────────────────────────────────────────────────────────────
# 로컬 환경에서 포트 충돌 시 아래 값을 변경하세요.
# 컨테이너 내부 통신 포트(예: redpanda:9092)는 고정값이므로 여기서 관리하지 않습니다.
PORT_MARIADB=3306
PORT_REDIS=6379
PORT_CLICKHOUSE_HTTP=8123
PORT_CLICKHOUSE_NATIVE=9000
PORT_REDPANDA_KAFKA=19092
PORT_REDPANDA_PROXY=18082
PORT_REDPANDA_SCHEMA=18081
PORT_REDPANDA_ADMIN=9644
PORT_REDPANDA_CONSOLE=8080
PORT_BACKEND=3000
PORT_GO_ENGINE=8081
PORT_FRONTEND_ADMIN=5174    # Master Admin UI  (공급자용)
PORT_FRONTEND_TENANT=5173   # Tenant UI        (고객사용)
PORT_ADMIN_GATEWAY=8088     # Prod 통합 진입점 (/admin, /tenant, /api)

